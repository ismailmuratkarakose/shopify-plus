# Bu dosyayı .env olarak kopyalayıp değerleri doldurun. .env git'e commit edilmez.

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
CATALOG_DB_NAME=catalog

# RabbitMQ
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Keycloak (yönetici bootstrap)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
