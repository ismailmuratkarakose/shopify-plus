{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/marketplace",
    "ValidIssuers": [
      "http://localhost:8080/realms/marketplace",
      "http://keycloak:8080/realms/marketplace"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "merchant-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/merchants/{**catch-all}"
        }
      },
      "shopify-route": {
        "ClusterId": "shopify-cluster",
        "Match": {
          "Path": "/api/shopify/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "merchant-cluster": {
        "Destinations": {
          "merchant": {
            "Address": "http://merchant:8080/"
          }
        }
      },
      "shopify-cluster": {
        "Destinations": {
          "shopify": {
            "Address": "http://shopifysync:8080/"
          }
        }
      }
    }
  }
}
