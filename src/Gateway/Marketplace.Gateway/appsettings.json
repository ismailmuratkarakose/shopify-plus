{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/marketplace",
    "ValidIssuers": [
      "http://localhost:8080/realms/marketplace",
      "http://keycloak:8080/realms/marketplace"
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "merchant-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/merchants/{**catch-all}"
        }
      },
      "shopify-route": {
        "ClusterId": "shopify-cluster",
        "Match": {
          "Path": "/api/shopify/{**catch-all}"
        }
      },
      "cms-route": {
        "ClusterId": "cms-cluster",
        "Match": {
          "Path": "/api/pages/{**catch-all}"
        }
      },
      "media-route": {
        "ClusterId": "cms-cluster",
        "Match": {
          "Path": "/api/media/{**catch-all}"
        }
      },
      "preview-route": {
        "ClusterId": "cms-cluster",
        "Match": {
          "Path": "/api/preview/{**catch-all}"
        }
      },
      "mobile-route": {
        "ClusterId": "mobile-cluster",
        "Match": {
          "Path": "/api/mobile/{**catch-all}"
        }
      },
      "flags-route": {
        "ClusterId": "cms-cluster",
        "Match": {
          "Path": "/api/flags/{**catch-all}"
        }
      },
      "experience-route": {
        "ClusterId": "cms-cluster",
        "Match": {
          "Path": "/api/experience/{**catch-all}"
        }
      },
      "users-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/users/{**catch-all}"
        }
      },
      "signup-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/signup/{**catch-all}"
        }
      },
      "signup-root-route": {
        "ClusterId": "merchant-cluster",
        "Match": {
          "Path": "/api/signup"
        }
      }
    },
    "Clusters": {
      "merchant-cluster": {
        "Destinations": {
          "merchant": {
            "Address": "http://merchant:8080/"
          }
        }
      },
      "shopify-cluster": {
        "Destinations": {
          "shopify": {
            "Address": "http://shopifysync:8080/"
          }
        }
      },
      "cms-cluster": {
        "Destinations": {
          "cms": {
            "Address": "http://cms:8080/"
          }
        }
      },
      "mobile-cluster": {
        "Destinations": {
          "mobile": {
            "Address": "http://mobile:8080/"
          }
        }
      }
    }
  }
}
