{
  "realm": "marketplace",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "owner",
        "description": "Pazaryeri sahibi / platform yöneticisi"
      },
      {
        "name": "platform-admin",
        "description": "Platform yöneticisi"
      },
      {
        "name": "merchant",
        "description": "Merchant kullanıcısı"
      },
      {
        "name": "store-admin",
        "description": "Mağaza yöneticisi: mağaza ayarları, kullanıcı yönetimi ve tüm içerik işlemleri"
      },
      {
        "name": "publish-manager",
        "description": "Yayın yöneticisi: içeriği onaylar, yayınlar, sürüm yönetir"
      },
      {
        "name": "content-editor",
        "description": "İçerik editörü: içerik hazırlar ve düzenler; yayınlayamaz"
      }
    ]
  },
  "clients": [
